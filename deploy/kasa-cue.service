[Unit]
Description=Kasa Cue Next.js app
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/var/www/kasa-cue
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=HOSTNAME=127.0.0.1
EnvironmentFile=/var/www/kasa-cue/.env.production
ExecStart=/usr/bin/node /var/www/kasa-cue/.next/standalone/server.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
